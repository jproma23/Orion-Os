[Desktop Entry]
Type=Application
Name=ORION X - Avatar (Fofao) em modo kiosk
Comment=Abre o Firefox em tela cheia mostrando o avatar do ORION X (Cap 13)
Exec=sh -c 'mkdir -p "$HOME/.mozilla/firefox/orion-avatar-kiosk"; exec firefox --profile "$HOME/.mozilla/firefox/orion-avatar-kiosk" --no-remote --kiosk http://127.0.0.1:8090'
X-GNOME-Autostart-enabled=true
NoDisplay=false
